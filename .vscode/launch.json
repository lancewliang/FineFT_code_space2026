    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "preprocess_data.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/FineFT/datahandler/preprocess_data.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/FineFT"
            },
            "args": "--trading_pair fu"
        },
        {
            "name": "slice_model.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/FineFT/datahandler/slice_model.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/FineFT"
            },
            "args": "--data_path dataset/fu/valid.feather --timestamp timestamp"
        },
        {
            "name": "vae_data_creation.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/FineFT/datahandler/vae_data_creation.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/FineFT"
            },
            "args": "--dataset_name fu"
        }
    ]
}
